# Podium Environment Configuration
# Copy to .env and fill in values

# ── Required ──────────────────────────────────────────────────────────────────

# Kaggle API credentials (for notebook/competition data collection)
# Get from: https://www.kaggle.com/settings → API → Create New Token
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# vLLM synthesis server auth (set any string, used to secure synthesis API)
VLLM_API_KEY=your_vllm_secret_key

# ── Synthesis (choose one or both) ────────────────────────────────────────────

# Anthropic API (fallback for complex reasoning synthesis pairs)
ANTHROPIC_API_KEY=sk-ant-api03-...

# vLLM synthesis server URL (for Qwen2.5-72B local/Azure synthesis)
VLLM_SYNTHESIS_URL=http://localhost:8000/v1

# ── Optional (recommended) ────────────────────────────────────────────────────

# Weights & Biases (training monitoring and experiment tracking)
WANDB_API_KEY=your_wandb_key
WANDB_PROJECT=podium-training
WANDB_ENTITY=your_wandb_username

# HuggingFace (model upload post-training)
HF_TOKEN=hf_...
HF_REPO=calebnewtonusc/podium-7b-v1

# ── Infrastructure ────────────────────────────────────────────────────────────

# Azure (for burst synthesis compute, 25k credits)
AZURE_SUBSCRIPTION_ID=your_subscription_id
AZURE_RESOURCE_GROUP=podium-synthesis
AZURE_REGION=eastus

# Docker (execution harness for CV-RL training)
DOCKER_EXECUTION_IMAGE=podium-execution:latest

# Redis (competition session state and solution cache)
REDIS_URL=redis://localhost:6379

# ── Training Config ───────────────────────────────────────────────────────────

# Base model (default: Qwen2.5-7B-Coder-Instruct)
BASE_MODEL=Qwen/Qwen2.5-7B-Coder-Instruct

# Training output directory
OUTPUT_DIR=./checkpoints

# Data directory (gitignored, store training data here)
DATA_DIR=./data

# Number of GPUs (default: 18 for full A6000 cluster)
NUM_GPUS=18

# ── Inference ─────────────────────────────────────────────────────────────────

# Port for Podium API server
API_PORT=8000

# Max concurrent competition sessions
MAX_CONCURRENT_COMPETITIONS=4

# Competition time budget default (hours)
DEFAULT_TIME_BUDGET_HOURS=168
